# Telegram Bot Token — получите у @BotFather
BOT_TOKEN=

# Yandex AI Studio API-ключ — получите в https://aistudio.yandex.ru
YANDEX_API_KEY=

# Yandex Cloud Folder ID — нужен для modelUri
YANDEX_FOLDER_ID=

# Путь к базе знаний (в Docker переопределяется на knowledge_base.json)
KB_PATH=data/knowledge_base.json
